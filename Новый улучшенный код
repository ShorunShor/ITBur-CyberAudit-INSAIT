# ---------- Основной класс аудитора ----------
class ITBurCyberAuditor:
    VERSION = "6.3"

    def __init__(self, no_color=False, gui_callback=None):
        self.находки = []
        self.флаги = set()
        self.нерасшифрованные_флаги = []
        self.подсказки_ctf = defaultdict(list)
        self.ошибки = []
        self.время_старта = datetime.now()
        self.имя_хоста = subprocess.getoutput("hostname")
        self.текущий_пользователь = subprocess.getoutput("whoami")
        self._добавленные_проблемы = set()
        self.статус_проверок = {}  # название_проверки: (статус_строка, пояснение)

        self.интернет_доступен = self._проверить_интернет()
        self.no_color = no_color
        self.gui_callback = gui_callback   # функция для отправки сообщений в GUI

    # ---------- Вспомогательные методы ----------
    def _log(self, message, color=None):
        """Вывод в консоль и/или GUI"""
        if self.gui_callback:
            self.gui_callback(message)
        if not self.no_color and color:
            print(f"{color}{message}{Colors.END}")
        else:
            print(message)

    def _проверить_интернет(self):
        try:
            socket.create_connection(("8.8.8.8", 53), timeout=3)
            return True
        except OSError:
            return False

    def _есть_утилита(self, имя):
        return shutil.which(имя) is not None

    def выполнить_команду(self, аргументы, использовать_sudo=False):
        try:
            if использовать_sudo and self.текущий_пользователь != 'root':
                аргументы = ['sudo'] + аргументы
            результат = subprocess.run(аргументы, capture_output=True, text=True, timeout=60)
            return результат.stdout.strip()
        except Exception as e:
            self.ошибки.append(f"Ошибка при выполнении {' '.join(аргументы)}: {str(e)}")
            return ""

    def добавить_находку(self, уровень, категория, описание, исправление, данные=None):
        ключ = f"{уровень}|{категория}|{описание}"
        if ключ in self._добавленные_проблемы:
            return
        self._добавленные_проблемы.add(ключ)
        запись = {
            'уровень': уровень,
            'категория': категория,
            'описание': описание,
            'исправление': исправление,
            'данные': данные or {}
        }
        self.находки.append(запись)
        цвета = {
            'КРИТИЧЕСКИЙ': Colors.RED,
            'ВЫСОКИЙ': Colors.YELLOW,
            'СРЕДНИЙ': Colors.BLUE,
            'ИНФО': Colors.CYAN
        }
        цвет = цвета.get(уровень, Colors.END)
        self._log(f"{цвет}[{уровень}]{Colors.END} {категория}: {описание}")
        self._log(f"  → Исправление: {исправление}\n")

    def _исключён(self, путь):
        путь_стр = str(путь)
        if any(путь_стр.startswith(д) for д in EXCLUDE_DIRS if '*' not in д):
            return True
        if any(шаблон in путь_стр for шаблон in ['.cache', '.local/share/Trash']):
            return True
        if any(путь_стр.endswith(расш) for расш in EXCLUDE_EXTENSIONS):
            return True
        if 'auditor' in путь_стр and (путь_стр.endswith('.py') or путь_стр.endswith('.pyc')):
            return True
        return False

    def _отметить_статус(self, название, успех, пояснение="", частично=False):
        """
        Установка статуса проверки.
        успех: True – полностью успешно, False – не выполнено или частично.
        частично: True – статус будет "частично выполнено" (если успех=False).
        """
        if успех:
            статус = "✅ выполнено"
        elif частично:
            статус = "⚠️ частично выполнено"
        else:
            статус = "❌ не выполнено"
        if not успех and not частично and not пояснение:
            пояснение = "неизвестная причина"
        self.статус_проверок[название] = (статус, пояснение)

    # ---------- 1. Анализ прав доступа ----------
    def аудит_прав(self):
        self._log(f"\n{Colors.BOLD}{Colors.BLUE}[1] Анализ прав доступа{Colors.END}")
        успех = True
        ошибки_здесь = []
        try:
            критические_папки = ['/etc', '/var/www', '/root', '/opt']
            for старт in критические_папки:
                if not os.path.exists(старт):
                    continue
                for корень, папки, файлы in os.walk(старт, topdown=True):
                    папки[:] = [п for п in папки if not self._исключён(os.path.join(корень, п))]
                    for имя in файлы:
                        путь = os.path.join(корень, имя)
                        if self._исключён(путь):
                            continue
                        try:
                            стат = os.stat(путь)
                        except Exception:
                            continue
                        режим = стат.st_mode & 0o7777
                        if режим & 0o777 == 0o777:
                            self.добавить_находку('КРИТИЧЕСКИЙ', 'Права 777',
                                                  f"Файл {путь} доступен всем",
                                                  f"sudo chmod 644 {путь}")
                        elif режим & 0o666 == 0o666:
                            self.добавить_находку('ВЫСОКИЙ', 'Права 666',
                                                  f"Файл {путь} доступен на запись всем",
                                                  f"sudo chmod 644 {путь}")
                        if режим & 0o4000 and путь not in SAFE_SUID:
                            self.добавить_находку('ВЫСОКИЙ', 'SUID-бит',
                                                  f"Файл {путь} имеет SUID (бит смены пользователя)",
                                                  f"sudo chmod u-s {путь}")
                        if режим & 0o2000:
                            self.добавить_находку('СРЕДНИЙ', 'SGID-бит',
                                                  f"Файл {путь} имеет SGID (бит смены группы)",
                                                  f"sudo chmod g-s {путь}")

            # Поиск конфиденциальных данных
            self._log(f"{Colors.BLUE}  Поиск конфиденциальных данных...{Colors.END}")
            паттерны = ['password', 'passwd', 'secret', 'key', 'cred', 'IDENTIFIED BY']
            for старт in ['/etc', '/var', '/home']:
                if not os.path.exists(старт):
                    continue
                for корень, папки, файлы in os.walk(старт):
                    папки[:] = [п for п in папки if not self._исключён(os.path.join(корень, п))]
                    for имя in файлы:
                        путь = os.path.join(корень, имя)
                        if self._исключён(путь) or not os.access(путь, os.R_OK):
                            continue
                        if os.path.getsize(путь) > 10*1024*1024:
                            continue
                        try:
                            with open(путь, 'r', errors='ignore') as f:
                                содержимое = f.read(200*1024)
                                for пат in паттерны:
                                    if пат.lower() in содержимое.lower():
                                        idx = содержимое.lower().find(пат.lower())
                                        фрагмент = содержимое[max(0, idx-30):min(len(содержимое), idx+70)]
                                        self.добавить_находку('ВЫСОКИЙ', 'Конфиденциальные данные',
                                                              f"Файл {путь} содержит '{пат}': {фрагмент}",
                                                              f"Проверьте содержимое: cat {путь}")
                                        break
                        except Exception:
                            continue

            # История БД
            файлы_истории = [os.path.expanduser("~/.mariadb_history"), "/root/.mariadb_history",
                             os.path.expanduser("~/.mysql_history"), "/root/.mysql_history"]
            for путь in файлы_истории:
                if os.path.exists(путь):
                    self.добавить_находку('ВЫСОКИЙ', 'История БД',
                                          f"Найден файл истории БД: {путь} (может содержать пароли)",
                                          f"Удалите или очистите: sudo rm {путь}")

            # Ярлыки меню
            десктоп_файлы = glob.glob('/usr/share/applications/*.desktop')
            подозрительные = []
            for дф in десктоп_файлы:
                try:
                    with open(дф, 'r', errors='ignore') as f:
                        if 'pkexec' in f.read() or 'sudo' in f.read():
                            подозрительные.append(дф)
                except Exception:
                    continue
            if подозрительные:
                self.добавить_находку('СРЕДНИЙ', 'Ярлыки меню',
                                      f"Найдены ярлыки запуска от root: {', '.join(подозрительные)}",
                                      "Проверьте файл /etc/sudoers и правила Polkit")
        except Exception as e:
            успех = False
            ошибки_здесь.append(str(e))
        if успех:
            self._отметить_статус("Анализ прав доступа", True, "")
        elif ошибки_здесь:
            self._отметить_статус("Анализ прав доступа", False, "; ".join(ошибки_здесь), частично=True)
        else:
            self._отметить_статус("Анализ прав доступа", False, "")

    # ---------- 2. Сетевой аудит ----------
    def аудит_сети(self):
        self._log(f"\n{Colors.BOLD}{Colors.BLUE}[2] Сетевой аудит{Colors.END}")
        успех = True
        ошибки_здесь = []
        открытые_порты = []
        есть_выполненные = False
        try:
            if not self._есть_утилита('ss'):
                сообщение = "Утилита ss не найдена, сканирование портов пропущено. Установите iproute2 (sudo apt install iproute2)."
                self.ошибки.append(сообщение)
                self.добавить_находку('ИНФО', 'Сетевой аудит', "ss не установлен, проверка портов невозможна",
                                      "Установите iproute2")
                ошибки_здесь.append(сообщение)
            else:
                вывод = self.выполнить_команду(['ss', '-tulpn'])
                for строка in вывод.splitlines():
                    совпадение = re.search(r'LISTEN\s+\d+\s+\d+\s+(?:[0-9.]+|\[::\]):(\d+)', строка)
                    if not совпадение:
                        continue
                    порт = int(совпадение.group(1))
                    if порт in DANGEROUS_PORTS:
                        self.добавить_находку('ВЫСОКИЙ', 'Опасный порт',
                                              f"Порт {порт} ({DANGEROUS_PORTS[порт]}) открыт",
                                              f"sudo ufw deny {порт} или остановите сервис",
                                              {'порт': порт})
                        открытые_порты.append((порт, DANGEROUS_PORTS[порт]))
                есть_выполненные = True

            # Баннеры через nc
            if not self._есть_утилита('nc'):
                сообщение = "nc не установлен, проверка баннеров пропущена. Установите netcat (sudo apt install netcat)."
                self.ошибки.append(сообщение)
                self.добавить_находку('ИНФО', 'Сетевой аудит', "nc не установлен, баннеры не проверялись",
                                      "Установите netcat")
                ошибки_здесь.append(сообщение)
            else:
                for порт in [21, 25, 80, 443, 3306, 5432]:
                    баннер = self.выполнить_команду(['timeout', '2', 'nc', '-v', 'localhost', str(порт)], использовать_sudo=False)
                    if 'bit26{' in баннер:
                        флаг = re.search(r'(bit26\{[^}]+\})', баннер)
                        if флаг:
                            self.флаги.add(флаг.group(1))
                            self._log(f"{Colors.GREEN}[+] Флаг в баннере порта {порт}: {флаг.group(1)}{Colors.END}")
                есть_выполненные = True

            # FTP анонимный доступ
            if not self._есть_утилита('ftp'):
                сообщение = "ftp не установлен, проверка анонимного FTP пропущена. Установите ftp-клиент (sudo apt install ftp)."
                self.ошибки.append(сообщение)
                self.добавить_находку('ИНФО', 'Сетевой аудит', "ftp не установлен, проверка FTP невозможна",
                                      "Установите ftp-клиент")
                ошибки_здесь.append(сообщение)
            else:
                ftp_тест = self.выполнить_команду("echo 'quit' | ftp -n localhost 2>/dev/null | grep -E '230 |220 '", использовать_sudo=False)
                if ftp_тест:
                    self.добавить_находку('КРИТИЧЕСКИЙ', 'FTP анонимный доступ',
                                          "Анонимный вход разрешён",
                                          "Отключите anonymous_enable в /etc/vsftpd.conf")
                есть_выполненные = True

            # Вывод таблицы открытых портов, если есть
            if открытые_порты and HAS_TABULATE:
                self._log(f"\n{Colors.BOLD}Обнаруженные открытые порты:{Colors.END}")
                таблица = tabulate(открытые_порты, headers=["Порт", "Сервис (расшифровка)"], tablefmt="grid")
                self._log(таблица)

            if есть_выполненные and ошибки_здесь:
                self._отметить_статус("Сетевой аудит", False, "; ".join(ошибки_здесь), частично=True)
            elif not есть_выполненные and ошибки_здесь:
                self._отметить_статус("Сетевой аудит", False, "; ".join(ошибки_здесь))
            else:
                self._отметить_статус("Сетевой аудит", True, "")
        except Exception as e:
            self._отметить_статус("Сетевой аудит", False, str(e))

    # ---------- 3. Аудит пакетов ----------
    def аудит_пакетов(self):
        self._log(f"\n{Colors.BOLD}{Colors.BLUE}[3] Аудит пакетов{Colors.END}")
        успех = True
        ошибки_здесь = []
        уязвимые_пакеты = []
        try:
            ядро = self.выполнить_команду(['uname', '-r'])
            self.добавить_находку('ИНФО', 'Ядро Linux', f"Версия: {ядро}",
                                  "sudo apt update && sudo apt upgrade linux-image")
            for пакет, версии in VULN_DB.items():
                версия = self.выполнить_команду(['dpkg-query', '-W', '-f=${Version}', пакет])
                if not версия:
                    continue
                for плохая_версия, cve in версии:
                    try:
                        if version.parse(версия) <= version.parse(плохая_версия):
                            self.добавить_находку('КРИТИЧЕСКИЙ', f'Уязвимый пакет {пакет}',
                                                  f"{пакет} {версия} — {cve}",
                                                  f"sudo apt update && sudo apt upgrade {пакет}")
                            уязвимые_пакеты.append((пакет, версия, cve))
                            break
                    except Exception:
                        continue
            if уязвимые_пакеты and HAS_TABULATE:
                self._log(f"\n{Colors.BOLD}Уязвимые пакеты:{Colors.END}")
                таблица = tabulate(уязвимые_пакеты, headers=["Пакет", "Версия", "CVE"], tablefmt="grid")
                self._log(таблица)
        except Exception as e:
            успех = False
            ошибки_здесь.append(str(e))
        if успех:
            self._отметить_статус("Аудит пакетов", True, "")
        elif ошибки_здесь:
            self._отметить_статус("Аудит пакетов", False, "; ".join(ошибки_здесь), частично=True)
        else:
            self._отметить_статус("Аудит пакетов", False, "")

    # ---------- 4. Поиск bit26-флагов (исправленный) ----------
    def поиск_флагов(self):
        self._log(f"\n{Colors.BOLD}{Colors.MAGENTA}[4] Поиск bit26-флагов{Colors.END}")
        успех = True
        ошибки_здесь = []
        try:
            # 4.1. Файловая система
            пути_поиска = ['/home', '/root', '/var/www', '/etc', '/opt', '/boot', '/var/log']
            for корень_поиска in пути_поиска:
                if not os.path.exists(корень_поиска):
                    continue
                for корень, папки, файлы in os.walk(корень_поиска):
                    папки[:] = [п for п in папки if not self._исключён(os.path.join(корень, п))]
                    for имя in файлы:
                        путь = os.path.join(корень, имя)
                        if self._исключён(путь):
                            continue
                        try:
                            with open(путь, 'r', errors='ignore') as f:
                                содержимое = f.read(5*1024*1024)
                                for совпад in re.finditer(r'(bit26\{[^}]+\})', содержимое):
                                    флаг = совпад.group(1)
                                    if len(флаг) > 7 and '...' not in флаг:
                                        self.флаги.add(флаг)
                                        self._log(f"{Colors.GREEN}[+] Флаг в файле: {флаг}{Colors.END}")
                        except Exception:
                            continue

            # 4.2. Firefox
            маски = [
                '/home/*/.mozilla/firefox/*.default/places.sqlite',
                '/home/*/.mozilla/firefox/*.default-release/places.sqlite',
                '/home/*/.mozilla/firefox/*.default-esr/places.sqlite',
            ]
            for маска in маски:
                for профиль in glob.glob(маска):
                    try:
                        conn = sqlite3.connect(f"file:{профиль}?mode=ro", uri=True)
                        c = conn.cursor()
                        c.execute("SELECT url, title FROM moz_places WHERE url LIKE '%bit26%' OR title LIKE '%bit26%'")
                        for url, title in c.fetchall():
                            for текст in [url, title]:
                                совпад = re.search(r'(bit26\{[^}]+\})', str(текст))
                                if совпад:
                                    self.флаги.add(совпад.group(1))
                                    self._log(f"{Colors.GREEN}[+] Флаг в Firefox: {совпад.group(1)}{Colors.END}")
                        conn.close()
                    except Exception:
                        pass

            # 4.3. История команд
            история_файлы = []
            for шаблон in ['/root/.bash_history', '/root/.zsh_history'] + \
                          glob.glob('/home/*/.bash_history') + \
                          glob.glob('/home/*/.zsh_history') + \
                          glob.glob('/home/*/.local/share/fish/fish_history'):
                история_файлы.append(шаблон)
            for путь in история_файлы:
                if os.path.exists(путь):
                    try:
                        with open(путь, 'r', errors='ignore') as f:
                            for строка in f:
                                совпад = re.search(r'(bit26\{[^}]+\})', строка)
                                if совпад:
                                    self.флаги.add(совпад.group(1))
                                    self._log(f"{Colors.GREEN}[+] Флаг в истории команд: {совпад.group(1)}{Colors.END}")
                    except Exception:
                        pass

            # 4.4. Переменные окружения
            env_out = subprocess.getoutput("env")
            for совпад in re.finditer(r'(bit26\{[^}]+\})', env_out):
                self.флаги.add(совпад.group(1))
                self._log(f"{Colors.GREEN}[+] Флаг в переменных окружения: {совпад.group(1)}{Colors.END}")

            # 4.5. Cron
            cron_out = self.выполнить_команду(['crontab', '-l'])
            for совпад in re.finditer(r'(bit26\{[^}]+\})', cron_out):
                self.флаги.add(совпад.group(1))
                self._log(f"{Colors.GREEN}[+] Флаг в cron: {совпад.group(1)}{Colors.END}")

            # 4.6. GRUB
            if os.path.exists('/boot/grub/grub.cfg'):
                try:
                    with open('/boot/grub/grub.cfg', 'r', errors='ignore') as f:
                        for совпад in re.finditer(r'(bit26\{[^}]+\})', f.read()):
                            self.флаги.add(совпад.group(1))
                            self._log(f"{Colors.GREEN}[+] Флаг в GRUB: {совпад.group(1)}{Colors.END}")
                except Exception:
                    pass

            # 4.7. Базы данных
            self._поиск_флагов_в_базах_данных()

            # 4.8. journalctl
            if not self._есть_утилита('journalctl'):
                сообщение = "journalctl не найден, проверка системного журнала пропущена. Установите systemd."
                self.ошибки.append(сообщение)
                self.добавить_находку('ИНФО', 'Поиск флагов', "journalctl не установлен, системный журнал не проверен",
                                      "Установите systemd")
                ошибки_здесь.append(сообщение)
            else:
                журнал = self.выполнить_команду(['sudo', 'journalctl', '-n', '5000'], использовать_sudo=True)
                for совпад in re.finditer(r'(bit26\{[^}]+\})', журнал):
                    self.флаги.add(совпад.group(1))
                    self._log(f"{Colors.GREEN}[+] Флаг в journalctl: {совпад.group(1)}{Colors.END}")

            # 4.9. Шифрованные строки (нерасшифрованные флаги) – ИСПРАВЛЕННЫЙ БЛОК
            шифрованные = self.выполнить_команду(['grep', '-r', '-E', 'СМИОТЗУИЯВРП|ОАТН|ИЬТУАСР', '/home', '/root'])
            if шифрованные:
                for строка in шифрованных.split('\n'):
                    совпад = re.search(r'(СМИОТЗУИЯВРП|ОАТН|ИЬТУАСР)', строка)
                    if совпад:
                        подсказка = совпад.group(1)
                        if подсказка not in self.нерасшифрованные_флаги:
                            self.нерасшифрованные_флаги.append(подсказка)
                self._log(f"{Colors.YELLOW}[!] Найдены зашифрованные строки (возможно, флаг после расшифровки):{Colors.END}")
                for подсказка in self.нерасшифрованные_флаги:
                    self._log(f"  {Colors.YELLOW}{подсказка}{Colors.END}")

            # 4.10. Веб-сервер
            веб_корень = '/var/www/html'
            if os.path.exists(веб_корень):
                for корень, папки, файлы in os.walk(веб_корень):
                    for имя in файлы:
                        путь = os.path.join(корень, имя)
                        try:
                            with open(путь, 'r', errors='ignore') as f:
                                содержимое = f.read(5*1024*1024)
                                for совпад in re.finditer(r'(bit26\{[^}]+\})', содержимое):
                                    self.флаги.add(совпад.group(1))
                                    self._log(f"{Colors.GREEN}[+] Флаг в веб-файле: {совпад.group(1)}{Colors.END}")
                        except Exception:
                            pass
        except Exception as e:
            успех = False
            ошибки_здесь.append(str(e))
        if успех:
            self._отметить_статус("Поиск bit26-флагов", True, "")
        elif ошибки_здесь:
            self._отметить_статус("Поиск bit26-флагов", False, "; ".join(ошибки_здесь), частично=True)
        else:
            self._отметить_статус("Поиск bit26-флагов", False, "")

    def _поиск_флагов_в_базах_данных(self):
        """Проверка MySQL, PostgreSQL, Redis, MongoDB, SQLite"""
        self._log(f"{Colors.BLUE}  Поиск флагов в базах данных...{Colors.END}")

        # MySQL / MariaDB
        if self._есть_утилита('mysql'):
            try:
                тест_бд = self.выполнить_команду(['mysql', '-u', 'root', '-e', 'show databases;'])
                if 'information_schema' in тест_бд:
                    for база in ['ctf', 'flags', 'test', 'cff', 'challenge']:
                        for таблица in ['flag', 'flags', 'secrets']:
                            запрос = f"select * from {таблица};"
                            результат = self.выполнить_команду(['mysql', '-u', 'root', '-D', база, '-e', запрос])
                            for совпад in re.finditer(r'(bit26\{[^}]+\})', результат):
                                self.флаги.add(совпад.group(1))
                                self._log(f"{Colors.GREEN}[+] Флаг в MySQL ({база}.{таблица}): {совпад.group(1)}{Colors.END}")
                else:
                    self._log(f"{Colors.YELLOW}  MySQL недоступен без пароля, проверка пропущена{Colors.END}")
            except Exception as e:
                self._log(f"{Colors.YELLOW}  Ошибка при подключении к MySQL: {e}{Colors.END}")
        else:
            self._log(f"{Colors.YELLOW}  Утилита mysql не установлена, проверка MySQL пропущена{Colors.END}")

        # PostgreSQL
        if self._есть_утилита('psql'):
            try:
                командная_строка = "psql -U postgres -d postgres -c \"SELECT table_schema, table_name FROM information_schema.tables WHERE table_name LIKE '%flag%' OR table_name LIKE '%secrets%';\""
                результат = self.выполнить_команду(командная_строка, использовать_sudo=False)
                if результат:
                    for совпад in re.finditer(r'(bit26\{[^}]+\})', результат):
                        self.флаги.add(совпад.group(1))
                        self._log(f"{Colors.GREEN}[+] Флаг в PostgreSQL: {совпад.group(1)}{Colors.END}")
                else:
                    self._log(f"{Colors.YELLOW}  PostgreSQL недоступен без пароля, проверка пропущена{Colors.END}")
            except Exception as e:
                self._log(f"{Colors.YELLOW}  Ошибка при подключении к PostgreSQL: {e}{Colors.END}")
        else:
            self._log(f"{Colors.YELLOW}  Утилита psql не установлена, проверка PostgreSQL пропущена{Colors.END}")

        # Redis
        if self._есть_утилита('redis-cli'):
            try:
                ключи = self.выполнить_команду(['redis-cli', 'KEYS', '*'])
                if ключи:
                    for ключ in ключи.splitlines():
                        значение = self.выполнить_команду(['redis-cli', 'GET', ключ])
                        for совпад in re.finditer(r'(bit26\{[^}]+\})', значение):
                            self.флаги.add(совпад.group(1))
                            self._log(f"{Colors.GREEN}[+] Флаг в Redis (ключ {ключ}): {совпад.group(1)}{Colors.END}")
                else:
                    self._log(f"{Colors.YELLOW}  Redis не содержит ключей или недоступен{Colors.END}")
            except Exception as e:
                self._log(f"{Colors.YELLOW}  Ошибка при подключении к Redis: {e}{Colors.END}")
        else:
            self._log(f"{Colors.YELLOW}  Утилита redis-cli не установлена, проверка Redis пропущена{Colors.END}")

        # MongoDB
        if self._есть_утилита('mongo'):
            try:
                скрипт = "db.getMongo().getDBNames().forEach(function(dbName) { var db = db.getSiblingDB(dbName); db.getCollectionNames().forEach(function(collName) { var coll = db.getCollection(collName); coll.find().forEach(function(doc) { printjson(doc); }); }); });"
                результат = self.выполнить_команду(['mongo', '--quiet', '--eval', скрипт])
                for совпад in re.finditer(r'(bit26\{[^}]+\})', результат):
                    self.флаги.add(совпад.group(1))
                    self._log(f"{Colors.GREEN}[+] Флаг в MongoDB: {совпад.group(1)}{Colors.END}")
                if not результат:
                    self._log(f"{Colors.YELLOW}  MongoDB недоступен без авторизации или пуст{Colors.END}")
            except Exception as e:
                self._log(f"{Colors.YELLOW}  Ошибка при подключении к MongoDB: {e}{Colors.END}")
        else:
            self._log(f"{Colors.YELLOW}  Утилита mongo не установлена, проверка MongoDB пропущена{Colors.END}")

        # SQLite (файлы баз данных)
        sqlite_файлы = []
        for корень in ['/', '/home', '/var', '/opt']:
            for root, dirs, files in os.walk(корень):
                for file in files:
                    if file.endswith(('.db', '.sqlite', '.sqlite3')):
                        путь = os.path.join(root, file)
                        if not self._исключён(путь):
                            sqlite_файлы.append(путь)
        for путь in sqlite_файлы:
            try:
                conn = sqlite3.connect(f"file:{путь}?mode=ro", uri=True)
                c = conn.cursor()
                c.execute("SELECT name FROM sqlite_master WHERE type='table';")
                таблицы = c.fetchall()
                for табл in таблицы:
                    try:
                        c.execute(f"SELECT * FROM {табл[0]};")
                        for строка in c.fetchall():
                            for поле in строка:
                                if isinstance(поле, str):
                                    for совпад in re.finditer(r'(bit26\{[^}]+\})', поле):
                                        self.флаги.add(совпад.group(1))
                                        self._log(f"{Colors.GREEN}[+] Флаг в SQLite ({путь}, {табл[0]}): {совпад.group(1)}{Colors.END}")
                    except:
                        continue
                conn.close()
            except Exception:
                pass

