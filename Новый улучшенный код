    # ---------- 8. Формирование отчёта ----------
    def сформировать_отчёт(self):
        длительность = (datetime.now() - self.время_старта).total_seconds()

        # Группируем находки по категориям и критичности
        сгруппировано_по_категориям = defaultdict(list)
        сгруппировано_по_критичности = defaultdict(list)
        for н in self.находки:
            сгруппировано_по_категориям[н['категория']].append(н)
            сгруппировано_по_критичности[н['уровень']].append(н)

        # Сортируем категории в логическом порядке
        порядок_категорий = [
            'Права 777', 'Права 666', 'SUID-бит', 'SGID-бит',
            'Конфиденциальные данные', 'История БД', 'Ярлыки меню',
            'Опасный порт', 'FTP анонимный доступ',
            'Ядро Linux', 'Уязвимый пакет openssh-server', 'Уязвимый пакет apache2',
            'Уязвимый пакет nginx', 'Уязвимый пакет mysql-server',
            'Уязвимый пакет mariadb-server', 'Уязвимый пакет postgresql',
            'Уязвимый пакет vsftpd', 'Уязвимый пакет samba', 'Уязвимый пакет openssl',
            'Уязвимый пакет php', 'Уязвимый пакет redis',
            'Sudo ALL', 'Sudo NOPASSWD', 'Подозрительные процессы',
            'Неудачные входы', 'Смена паролей',
            'Брандмауэр UFW отключён', 'Настройки UFW', 'Брандмауэр отсутствует'
        ]
        отсортированные_категории = [кат for кат in порядок_категорий if кат in сгруппировано_по_категориям]
        отсортированные_категории += [кат for кат in сгруппировано_по_категориям.keys() if кат not in отсортированные_категории]

        # Статистика по критичности
        статистика_критичности = {ур: len(список) for ур, список in сгруппировано_по_критичности.items()}

        # ---------- Фильтрация флагов ----------
        валидные_флаги = []
        for ф in self.флаги:
            if isinstance(ф, str) and ф.startswith('bit26{') and ф.endswith('}'):
                внутрь = ф[6:-1]
                # Исключаем мусор
                if (not any(c in внутрь for c in '"\'[]()') and
                    not внутрь.startswith('полученный') and
                    not внутрь.startswith('расшифрованный') and
                    not внутрь.startswith('флаг') and
                    not внутрь.endswith('...') and
                    'f.endswith' not in внутрь and
                    'флаг.endswith' not in внутрь and
                    '...' not in внутрь and
                    len(внутрь) > 3):
                    валидные_флаги.append(ф)
        валидные_флаги = sorted(валидные_флаги)

        # ---------- Нерасшифрованные флаги ----------
        нерасшифрованные = sorted(set(self.нерасшифрованные_флаги))

        # ---------- Статистика по проверкам ----------
        успешные_проверки = 0
        частичные_проверки = 0
        неудачные_проверки = 0
        for статус, _ in self.статус_проверок.values():
            if "✅" in статус:
                успешные_проверки += 1
            elif "⚠️" in статус:
                частичные_проверки += 1
            else:
                неудачные_проверки += 1

        # ---------- Формируем JSON ----------
        отчёт = {
            "информация_о_сканировании": {
                "версия_аудитора": self.VERSION,
                "имя_хоста": self.имя_хоста,
                "имя_компьютера": self.имя_хоста,
                "пользователь": self.текущий_пользователь,
                "время_сканирования": self.время_старта.isoformat(),
                "длительность_сек": round(длительность, 2),
                "всего_находок": len(self.находки),
                "всего_флагов": len(валидные_флаги),
                "всего_нерасшифрованных_флагов": len(нерасшифрованные),
                "интернет_доступен": self.интернет_доступен,
                "ошибки": self.ошибки,
                "статус_проверок": self.статус_проверок,
                "статистика_по_критичности": статистика_критичности,
                "статистика_по_проверкам": {
                    "всего_проверок": len(self.статус_проверок),
                    "успешно": успешные_проверки,
                    "частично": частичные_проверки,
                    "неудачно": неудачные_проверки
                }
            },
            "найденные_флаги": валидные_флаги,
            "нерасшифрованные_флаги": нерасшифрованные,
            "находки_по_категориям": {кат: сгруппировано_по_категориям[кат] for кат in отсортированные_категории},
            "находки_по_критичности": dict(сгруппировано_по_критичности)
        }

        имя_файла = f"audit_report_{datetime.now().strftime('%Y%m%d_%H%M%S')}.json"
        with open(имя_файла, 'w', encoding='utf-8') as f:
            json.dump(отчёт, f, indent=2, ensure_ascii=False)

        # ---------- КОНСОЛЬНЫЙ ВЫВОД ----------
        self._log(f"\n{Colors.BOLD}{Colors.GREEN}{'='*80}{Colors.END}")
        self._log(f"{Colors.BOLD}{Colors.GREEN}║{' '*30}ИТОГОВЫЙ ОТЧЁТ АУДИТА{' '*30}║{Colors.END}")
        self._log(f"{Colors.BOLD}{Colors.GREEN}{'='*80}{Colors.END}")
        self._log(f"Хост: {self.имя_хоста} (имя компьютера)")
        self._log(f"Пользователь: {self.текущий_пользователь}")
        self._log(f"Время сканирования: {длительность:.2f} сек")
        self._log(f"Найдено проблем: {len(self.находки)}")
        self._log(f"Найдено bit26-флагов: {len(валидные_флаги)}")
        self._log(f"Нерасшифрованных флагов: {len(нерасшифрованные)}")

        # Статистика по критичности
        if статистика_критичности:
            self._log(f"\n{Colors.BOLD}📊 Статистика по критичности:{Colors.END}")
            for уровень, кол in статистика_критичности.items():
                цвет = {'КРИТИЧЕСКИЙ': Colors.RED, 'ВЫСОКИЙ': Colors.YELLOW, 'СРЕДНИЙ': Colors.BLUE, 'ИНФО': Colors.CYAN}.get(уровень, Colors.END)
                self._log(f"  {цвет}{уровень}{Colors.END}: {кол}")

        # Статус выполнения проверок
        self._log(f"\n{Colors.BOLD}🔍 Статус выполнения проверок:{Colors.END}")
        self._log(f"  Всего проверок: {len(self.статус_проверок)}")
        self._log(f"  ✅ Успешно: {успешные_проверки}")
        self._log(f"  ⚠️ Частично: {частичные_проверки}")
        self._log(f"  ❌ Неудачно: {неудачные_проверки}")

        # Детализация проверок, которые не выполнены полностью
        if частичные_проверки > 0 or неудачные_проверки > 0:
            self._log(f"\n{Colors.BOLD}{Colors.YELLOW}⚠ Детализация не полностью выполненных проверок:{Colors.END}")
            for название, (статус, пояснение) in self.статус_проверок.items():
                if "✅" not in статус:
                    self._log(f"  {статус} {название}")
                    if пояснение:
                        self._log(f"    {Colors.YELLOW}Причина: {пояснение}{Colors.END}")

        # Ошибки, возникшие во время работы
        if self.ошибки:
            self._log(f"\n{Colors.BOLD}{Colors.RED}⚠ Ошибки при выполнении команд:{Colors.END}")
            for err in self.ошибки:
                self._log(f"  {Colors.RED}• {err}{Colors.END}")

        # Найденные флаги
        if валидные_флаги:
            self._log(f"\n{Colors.BOLD}{Colors.GREEN}🏆 НАЙДЕННЫЕ BIT26-ФЛАГИ (расшифрованные):{Colors.END}")
            for флаг in валидные_флаги:
                self._log(f"  {Colors.GREEN}{флаг}{Colors.END}")
        else:
            self._log(f"\n{Colors.BOLD}{Colors.YELLOW}🏆 Найденные bit26-флаги (расшифрованные):{Colors.END}")
            self._log(f"  {Colors.YELLOW}Флаги не обнаружены.{Colors.END}")

        # Нерасшифрованные флаги
        if нерасшифрованные:
            self._log(f"\n{Colors.BOLD}{Colors.YELLOW}🔐 ФЛАГИ, ТРЕБУЮЩИЕ РАСШИФРОВКИ:{Colors.END}")
            for подсказка in нерасшифрованные:
                self._log(f"  {Colors.YELLOW}{подсказка}{Colors.END}")
        else:
            self._log(f"\n{Colors.BOLD}{Colors.YELLOW}🔐 Флаги, требующие расшифровки:{Colors.END}")
            self._log(f"  {Colors.YELLOW}Нерасшифрованные флаги не обнаружены.{Colors.END}")

        # Сообщение о сохранении JSON
        self._log(f"\n{Colors.BOLD}{Colors.CYAN}📄 Полный отчёт сохранён в файл:{Colors.END} {имя_файла}")

        if not self.no_color and self.gui_callback is None:
            self._log(f"\n{Colors.BOLD}💡 Совет:{Colors.END} Для просмотра отчёта в удобном виде откройте файл {имя_файла} любым текстовым редактором.")

    # ---------- Запуск всех проверок ----------
    def запустить_всё(self):
        self._log(BANNER)
        self._log(f"{Colors.CYAN}Запуск полного аудита безопасности...{Colors.END}\n")

        self.аудит_прав()
        self.аудит_сети()
        self.аудит_пакетов()
        self.поиск_флагов()
        self.проверка_привилегий()
        self.аудит_журналов()
        self.проверка_брандмауэра()
        self.сформировать_отчёт()

# ---------- GUI на Tkinter (улучшенная) ----------
def запустить_gui():
    try:
        import tkinter as tk
        from tkinter import scrolledtext, messagebox, ttk
    except ImportError:
        print("Tkinter не установлен. Используйте CLI режим.")
        return

    root = tk.Tk()
    root.title("ITBur Cyber Auditor v6.3 — Графический интерфейс пользователя (GUI)")
    root.geometry("1000x750")
    root.resizable(True, True)

    # Основной фрейм
    main_frame = ttk.Frame(root, padding="10")
    main_frame.grid(row=0, column=0, sticky=(tk.W, tk.E, tk.N, tk.S))
    root.columnconfigure(0, weight=1)
    root.rowconfigure(0, weight=1)
    main_frame.columnconfigure(0, weight=1)
    main_frame.rowconfigure(0, weight=1)

    # Заголовок
    title = ttk.Label(main_frame, text="ITBur Cyber Auditor v6.3", font=("Arial", 16, "bold"))
    title.grid(row=0, column=0, pady=5)

    # Область вывода
    output_area = scrolledtext.ScrolledText(main_frame, wrap=tk.WORD, width=100, height=30, font=("Courier", 10))
    output_area.grid(row=1, column=0, sticky=(tk.W, tk.E, tk.N, tk.S), pady=10)

    # Функция для вывода в GUI
    def gui_write(message):
        output_area.insert(tk.END, message + "\n")
        output_area.see(tk.END)
        root.update_idletasks()

    # Панель кнопок
    button_frame = ttk.Frame(main_frame)
    button_frame.grid(row=2, column=0, pady=5)

    def run_audit():
        output_area.delete(1.0, tk.END)
        gui_write("Запуск аудита...\n")
        def target():
            auditor = ITBurCyberAuditor(no_color=True, gui_callback=gui_write)
            auditor.запустить_всё()
            gui_write("\nАудит завершён.")
        threading.Thread(target=target, daemon=True).start()

    ttk.Button(button_frame, text="Запустить полный аудит", command=run_audit).pack(side=tk.LEFT, padx=5)

    def clear_output():
        output_area.delete(1.0, tk.END)
    ttk.Button(button_frame, text="Очистить вывод", command=clear_output).pack(side=tk.LEFT, padx=5)

    # Строка статуса
    status_var = tk.StringVar()
    status_var.set("Готов к работе. Нажмите кнопку для запуска аудита.")
    status_bar = ttk.Label(main_frame, textvariable=status_var, relief=tk.SUNKEN, anchor=tk.W)
    status_bar.grid(row=3, column=0, sticky=(tk.W, tk.E), pady=5)

    root.mainloop()

# ---------- Обработчик прерывания ----------
def обработчик_прерывания(sig, frame):
    print(f"\n{Colors.YELLOW}Прерывание пользователем. Сохраняю найденные результаты...{Colors.END}")
    if 'auditor' in globals():
        auditor.сформировать_отчёт()
    sys.exit(0)

# ---------- Проверка зависимостей ----------
def проверить_зависимости():
    missing = []
    try:
        import packaging
    except ImportError:
        missing.append("packaging")
    if missing:
        print(f"{Colors.YELLOW}⚠ Отсутствуют необходимые Python-пакеты: {', '.join(missing)}{Colors.END}")
        print(f"Установите их командой: pip install {' '.join(missing)}")
        print("Затем перезапустите скрипт.")
        sys.exit(1)

# ---------- Точка входа ----------
if __name__ == "__main__":
    проверить_зависимости()

    # Парсер аргументов командной строки
    parser = argparse.ArgumentParser(description='ITBur Cyber Auditor - инструмент аудита безопасности Linux')
    parser.add_argument('--no-color', action='store_true', help='Отключить цветной вывод')
    parser.add_argument('--check', nargs='+', choices=['file_perm', 'network', 'packages', 'flags', 'privileges', 'logs', 'firewall', 'all'],
                        help='Выборочные проверки (по умолчанию all)')
    parser.add_argument('--gui', action='store_true', help='Запустить графический интерфейс')
    args = parser.parse_args()

    signal.signal(signal.SIGINT, обработчик_прерывания)

    # Если запрошен GUI или нет аргументов и tkinter доступен
    if args.gui or (len(sys.argv) == 1 and '--help' not in sys.argv):
        try:
            import tkinter
            запустить_gui()
            sys.exit(0)
        except ImportError:
            print("Tkinter не установлен. Запуск в CLI режиме.")
            # продолжим CLI

    # CLI режим
    if os.geteuid() != 0:
        print(f"{Colors.YELLOW}Для полного аудита рекомендуется запуск с sudo.{Colors.END}\n")

    auditor = ITBurCyberAuditor(no_color=args.no_color)

    # Выборочный запуск проверок
    checks = args.check if args.check else ['all']
    if 'all' in checks:
        auditor.запустить_всё()
    else:
        if 'file_perm' in checks:
            auditor.аудит_прав()
        if 'network' in checks:
            auditor.аудит_сети()
        if 'packages' in checks:
            auditor.аудит_пакетов()
        if 'flags' in checks:
            auditor.поиск_флагов()
        if 'privileges' in checks:
            auditor.проверка_привилегий()
        if 'logs' in checks:
            auditor.аудит_журналов()
        if 'firewall' in checks:
            auditor.проверка_брандмауэра()
        auditor.сформировать_отчёт()
